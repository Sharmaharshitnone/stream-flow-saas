# AWS Credentials (required)
# Obtain from: https://console.aws.amazon.com/iam/home
# Recommendation: Create an IAM user with S3 + DynamoDB + CloudFront access only
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# AWS Region (must match Terraform deployment region)
# Deployed to: us-east-1
AWS_REGION=us-east-1

# Environment Mode
NODE_ENV=development

# Debug Logging
DEBUG=false

# Note: Bucket names and table names are auto-discovered from Terraform state
# or can be hardcoded if state is inaccessible.
# In production, inject via Lambda environment variables.
